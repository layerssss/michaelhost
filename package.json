{
  "name": "michaelhost",
  "version": "1.3.0",
  "license": "MIT",
  "scripts": {
    "build": "cd admin_ui && yarn build",
    "cli": "NODE_ENV=dev node ./bin/michaelhost.js",
    "dev_node": "NODE_ENV=dev node ./bin/michaelhost.js service --admin-port 2002 --webhook-server-port 2001 --secret ${MICHAELHOST_SECRET:-notsuchasecret}",
    "dev_react": "cd admin_ui && yarn start",
    "lint": "eslint .",
    "format": "prettier --write './lib/**/*.js' './bin/**/*.js' './admin_ui/src/**/*.js'",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "bin": {
    "michaelhost": "bin/michaelhost.js"
  },
  "dependencies": {
    "apollo-server-express": "^2.21.1",
    "body-parser": "^1.18.3",
    "bunyan": "^1.8.15",
    "bunyan-prettystream": "^0.1.3",
    "commander": "^7.1.0",
    "dockerode": "^3.2.1",
    "express": "^4.16.3",
    "graphql": "^15.5.0",
    "homedir": "^0.6.0",
    "lodash": "^4.17.21",
    "node-cron": "^2.0.3",
    "node-fetch": "^2.6.1",
    "node-pty": "^1.1.0",
    "rollbar": "^2.21.0",
    "secure-compare": "^3.0.1",
    "semver": "^7.3.4",
    "uuid": "^14.0.0",
    "shell-quote": "^1.7.2",
    "strip-ansi": "^6.0.0",
    "ws": "^7.4.4"
  },
  "devDependencies": {
    "eslint": "^7.30.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.3.1",
    "prettier": "^2.2.1"
  }
}
